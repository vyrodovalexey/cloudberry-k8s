      },
      "options": {}
    },
    {
      "id": 26,
      "type": "traces",
      "title": "Error Spans",
      "description": "All operator spans with error status.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 12,
        "y": 62,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"cloudberry-operator\" && status = error }",
          "tableType": "traces",
          "limit": 50
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    }
  ]
}
