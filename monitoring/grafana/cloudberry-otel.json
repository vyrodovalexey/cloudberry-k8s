{
  "uid": "cloudberry-otel",
  "title": "Cloudberry OTEL / Telemetry",
  "tags": [
    "cloudberry",
    "otel",
    "telemetry"
  ],
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Traces",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "traces",
      "title": "Operator Spans (service.name=cloudberry-operator)",
      "description": "Explore operator traces from Tempo. Spans include Reconcile, handleMigrate, vault.*, EnsureCertificates, API '<METHOD> <path>', reconcileBackup, runFTSProbe, handleFailover.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"cloudberry-operator\" }",
          "tableType": "traces",
          "limit": 50
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "type": "row",
      "title": "OTEL Collector Health",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Spans Received vs Exported (rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(otelcol_receiver_accepted_spans[5m]))",
          "legendFormat": "received",
          "refId": "A"
        },
        {
          "expr": "sum(rate(otelcol_exporter_sent_spans[5m]))",
          "legendFormat": "exported",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Exporter Send Failures (rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(otelcol_exporter_send_failed_spans[5m]))",
          "legendFormat": "send failed spans",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Exporter Queue Size",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(otelcol_exporter_queue_size)",
          "legendFormat": "queue size",
          "refId": "A"
        },
        {
          "expr": "sum(otelcol_exporter_queue_capacity)",
          "legendFormat": "queue capacity",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Batch Processor (batch size sum rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(otelcol_processor_batch_batch_send_size_sum[5m]))",
          "legendFormat": "batch send size",
          "refId": "A"
        },
        {
          "expr": "sum(rate(otelcol_processor_batch_timeout_trigger_send[5m]))",
          "legendFormat": "timeout trigger send",
          "refId": "B"
        },
        {
          "expr": "sum(rate(otelcol_processor_batch_batch_size_trigger_send[5m]))",
          "legendFormat": "size trigger send",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Spans Received (5m rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(otelcol_receiver_accepted_spans[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Refused Spans (5m rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "x": 6,
        "y": 28,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(otelcol_receiver_refused_spans[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Send Failed Spans (5m rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(otelcol_exporter_send_failed_spans[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Spans Exported (5m rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "x": 18,
        "y": 28,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(otelcol_exporter_sent_spans[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 12,
      "type": "row",
      "title": "Logs",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 13,
      "type": "logs",
      "title": "Operator Pod Logs (cloudberry-operator)",
      "description": "Operator logs from VictoriaLogs for correlation with traces.",
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "victorialogs"
          },
          "expr": "kubernetes.pod_namespace:cloudberry-test AND kubernetes.container_name:cloudberry-operator",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Span Coverage by Category (TraceQL)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 45,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 21,
      "type": "traces",
      "title": "API HTTP Spans (METHOD route)",
      "description": "Server spans named '<METHOD> <route-template>' emitted by the API HTTP middleware.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"cloudberry-operator\" && name =~ \"(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS) .*\" }",
          "tableType": "traces",
          "limit": 50
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 22,
      "type": "traces",
      "title": "Database Spans (db.*)",
      "description": "Database connect/query spans: db.connect, db.query, db.pool operations.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 12,
        "y": 46,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"cloudberry-operator\" && name =~ \"db\\\\..*\" }",
          "tableType": "traces",
          "limit": 50
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 23,
      "type": "traces",
      "title": "Controller & Operator Spans (controller.*, operator.*)",
      "description": "Reconcile loop and operator lifecycle spans.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 54,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"cloudberry-operator\" && name =~ \"(controller|operator)\\\\..*\" }",
          "tableType": "traces",
          "limit": 50
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 24,
      "type": "traces",
      "title": "Idle Daemon Spans (idle.*)",
      "description": "Idle session daemon scan/terminate/reconnect spans.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 12,
        "y": 54,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"cloudberry-operator\" && name =~ \"idle\\\\..*\" }",
          "tableType": "traces",
          "limit": 50
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 25,
      "type": "traces",
      "title": "Auth & Webhook Spans (auth.*, webhook.*)",
      "description": "Bearer/OIDC token verification and admission webhook spans.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 62,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"cloudberry-operator\" && name =~ \"(auth|webhook)\\\\..*\" }",
          "tableType": "traces",
          "limit": 50
        }
      ],
      "fieldConfig": {
        "defaults": {},
