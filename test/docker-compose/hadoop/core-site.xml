<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  Core Hadoop configuration shared by the HDFS NameNode/DataNode and Hive.
  Mounted into every Hadoop/Hive container at $HADOOP_CONF_DIR.

  fs.defaultFS matches the PXF server config documented in
  specifications/12-data-loading-spec.md (hdfs://namenode:8020), so PXF
  external tables created against the in-cluster `hadoop-cluster` server
  resolve to this test HDFS.
-->
<configuration>
  <property>
    <name>fs.defaultFS</name>
    <value>hdfs://namenode:8020</value>
  </property>
  <property>
    <name>hadoop.tmp.dir</name>
    <value>/tmp/hadoop</value>
  </property>
  <!-- Allow Hive/PXF (running as arbitrary users) to impersonate, required for
       the metastore + HiveServer2 proxy users in this single-node test env. -->
  <property>
    <name>hadoop.proxyuser.hive.hosts</name>
    <value>*</value>
  </property>
  <property>
    <name>hadoop.proxyuser.hive.groups</name>
    <value>*</value>
  </property>
  <property>
    <name>hadoop.proxyuser.root.hosts</name>
    <value>*</value>
  </property>
  <property>
    <name>hadoop.proxyuser.root.groups</name>
    <value>*</value>
  </property>
</configuration>
